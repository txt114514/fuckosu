{
  "name": "osu-ai-dev-container",
  "dockerComposeFile": [
    "docker-compose.yml"
  ],

  "service": "osu-dev",

  "workspaceFolder": "/home/dev/workspace",

  "remoteUser": "dev",

  "shutdownAction": "stopCompose",

  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python3",
        "python.terminal.activateEnvironment": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "eamodio.gitlens",
        "openai.chatgpt"
      ]
    }
  }
}