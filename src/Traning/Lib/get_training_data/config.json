{
    // 进度与状态管理。
    // process_steps 决定 process_status.json 的完整步骤顺序。
    // status_steps 决定每个阶段写入哪个状态名。
    // required_steps 决定每个阶段开始前要求完成的前置步骤。
    "progress": {
        "process_steps": [
            "osu_imported",
            "audio_imported",
            "verify_exported",
            "difficulty_exported",
            "video_matched",
            "av_corresponded",
            "video_processed"
        ],
        "status_steps": {
            "av_correspondence": "av_corresponded",
            "clip": "video_processed"
        },
        "required_steps": {
            "av_correspondence": [
                "audio_imported",
                "video_matched"
            ],
            "clip": [
                "av_corresponded"
            ]
        }
    },

    // 路径与文件名管理。
    // 这里集中放“文件在哪”和“文件叫什么”这类配置。
    "file_management": {
        "export_dir": "../../../../osu-lazer/exports",
        "target_root": "../../../../training_package/match-completed_package",
        "video_root": "../../../../training_package/video_package",
        "order_filename": "order.txt",
        "verify_filename": "verify.txt",
        "difficulty_filename": "difficulty.txt",
        "verify_failed_filename": "verify_failed.txt",
        "difficulty_failed_filename": "difficulty_failed.txt",
        "audio_filename": "audio.mp3",
        "output_filename": "video_processed.mp4",
        "av_correspondence_failed_filename": "av_correspondence_failed.txt",
        "clip_failed_filename": "clip_failed.txt"
    },

    // 文件匹配与格式管理。
    // keyword 用于选择目标 .osu。
    // video_suffixes 用于识别允许的视频格式。
    "file_formats": {
        "keyword": "normal",
        "video_suffixes": [
            ".mp4",
            ".webm",
            ".mkv",
            ".avi",
            ".mov"
        ]
    },

    // 实际处理参数。
    // 这里集中放算法、裁剪框等真正影响处理结果的参数。
    "parameters": {
        "av_correspondence": {
            "sample_rate": 8000,
            "envelope_hz": 100,
            "refine_hz": 1000,
            "refine_search_seconds": 1.5
        },
        "clip": {
            // 裁剪框基于参考图 2048x1152 定义，再按比例映射到实际视频。
            "crop_reference_width": 2048,
            "crop_reference_height": 1152,
            "crop_left": 186,
            "crop_top": 178,
            "crop_right": 1768,
            "crop_bottom": 1080
        }
    }
}
